# Copia este archivo a ".env" y ajusta los valores. NO subas tu .env real.

# --- Servidor ---
# SERVER_ADDR=:8080
# WEB_DIR=web/dist
# UPLOAD_DIR=./uploads

# --- Seguridad (OBLIGATORIO en producción) ---
# Genera un valor largo y aleatorio. En producción el servidor NO arranca con
# el valor por defecto inseguro.
# JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- Base de datos MySQL ---
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=story_go_db

# --- Email (reset de contraseña) ---
# URL pública de la app, usada en los enlaces de los correos.
# APP_BASE_URL=http://localhost:8090
# Si dejas SMTP_HOST vacío, los correos NO se envían: se escriben en el log del
# servidor (perfecto para desarrollo). Para enviar de verdad en local, instala
# Mailpit (brew install mailpit; mailpit) y usa SMTP_HOST=localhost SMTP_PORT=1025.
# SMTP_HOST=
# SMTP_PORT=1025
# SMTP_FROM=no-reply@story.local

# --- Login con Google (OPCIONAL) ---
# Si dejas GOOGLE_CLIENT_ID vacío, el login con Google queda deshabilitado y
# el servidor arranca igual.
#
# Cómo obtener las credenciales (hazlo con un adulto):
#  1. Entra a https://console.cloud.google.com y crea un proyecto.
#  2. "APIs y servicios" -> "Credenciales" -> "Crear credenciales" ->
#     "ID de cliente de OAuth" -> tipo "Aplicación web".
#  3. En "URIs de redireccionamiento autorizados" agrega:
#        http://localhost:5173/auth/oauth/callback
#  4. Copia el Client ID y el Client Secret aquí abajo.
#  5. El MISMO Client ID va también en web/.env como VITE_GOOGLE_CLIENT_ID.
#
# GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=tu-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/oauth/callback
