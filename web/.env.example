# Copia este archivo a "web/.env". Variables del frontend (Vite).
# Deben empezar con VITE_ para que Vite las exponga al navegador.

# Client ID de Google (el MISMO que GOOGLE_CLIENT_ID del backend).
# Sin esto, el botón "Iniciar sesión con Google" avisa que falta configuración.
# VITE_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
